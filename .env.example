POSTGRES_DB=soc_management
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
APP_ENV=development
APP_PORT=3000
JWT_SECRET=change_this_to_a_long_random_secret_please
JWT_EXPIRES_IN=24h
DB_HOST=postgres
DB_PORT=5432
DB_NAME=soc_management
DB_USER=postgres
DB_PASSWORD=postgres
VITE_APP_NAME=SOC Management
VITE_API_BASE_URL=[localhost](http://localhost:3000/api)

# LDAP Configuration (optional - leave blank to use local auth only)
LDAP_URL=ldap://your-ldap-server:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=your-ldap-password
LDAP_SEARCH_BASE=dc=example,dc=com
LDAP_SEARCH_FILTER=(mail={username})
LDAP_TLS=false